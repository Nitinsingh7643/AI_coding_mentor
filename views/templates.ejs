<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Coding Mentor - Templates</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="/styles.css" rel="stylesheet" />
    <style>
        .templates-wrapper {
            padding: 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }
        .header-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        .header-actions h2 {
            font-size: 1.5rem;
            color: var(--text-primary);
            margin: 0;
        }
        .filters {
            display: flex;
            gap: 1rem;
        }
        .filter-btn {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.5rem 1rem;
            border-radius: var(--radius-full);
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 0.9rem;
        }
        .filter-btn.active, .filter-btn:hover {
            background: rgba(59, 130, 246, 0.1);
            color: var(--primary-color);
            border-color: var(--primary-color);
        }
        .template-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.5rem;
        }
        .template-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: var(--radius-md);
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        .template-card:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: var(--primary-color);
        }
        .template-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #3b82f6, #8b5cf6);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .template-card:hover::before {
            opacity: 1;
        }
        .tc-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .tc-title {
            color: var(--text-primary);
            font-weight: 600;
            font-size: 1.1rem;
            margin: 0;
        }
        .tc-desc {
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.5;
            flex-grow: 1;
        }
        .tc-tags {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        .tc-tag {
            font-size: 0.75rem;
            background: var(--bg-body);
            color: var(--text-secondary);
            padding: 2px 8px;
            border-radius: 4px;
            border: 1px solid var(--border-color);
        }
        .tc-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
            border-top: 1px solid var(--border-color);
            padding-top: 1rem;
        }
        .tc-btn {
            background: var(--primary-color);
            color: #fff;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 6px;
            font-weight: 500;
            cursor: pointer;
            transition: background 0.2s;
            text-decoration: none;
            font-size: 0.9rem;
        }
        .tc-btn:hover {
            background: #2563eb;
        }
        .tc-icon {
            font-size: 1.5rem;
        }
    </style>
</head>
<body class="<%= theme === 'light' ? 'light-mode' : '' %>">
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="brand-section">
                <div class="brand">
                    <img src="/logo.png" alt="AI" class="logo-img">
                    <h1>AI.Mentor</h1>
                </div>
            </div>
            <nav class="nav-menu">
                <a href="/app" class="nav-item">
                    <span>🚀</span> Editor
                </a>
                <a href="/history" class="nav-item">
                    <span>📚</span> History
                </a>
                <a href="/templates" class="nav-item active">
                    <span>🧩</span> Templates
                </a>
                <a href="/dashboard" class="nav-item">
                    <span>📊</span> Analytics
                </a>
                <a href="/settings" class="nav-item">
                    <span>⚙️</span> Settings
                </a>
            </nav>
            <div class="sidebar-footer">
                <div class="nav-item">
                    <span>💎</span> Go Pro
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="top-bar">
                <div class="project-info">
                    <span style="font-weight:600; color:var(--text-primary);">Template Library</span>
                </div>
                <div class="top-controls">
                    <button class="theme-toggle-btn" onclick="toggleTheme()">🌙</button>
                    <div class="profile-avatar" style="width:32px; height:32px; background:#3b82f6; border-radius:50%;"></div>
                </div>
            </header>

            <div class="templates-wrapper">
                <div class="header-actions">
                    <h2>Starter Snippets & Boilerplates</h2>
                    <div class="filters">
                        <button class="filter-btn active">All</button>
                        <button class="filter-btn">React</button>
                        <button class="filter-btn">Node.js</button>
                        <button class="filter-btn">Python</button>
                        <button class="filter-btn">Algorithms</button>
                    </div>
                </div>

                <div class="template-grid">
                    <!-- Template 1 -->
                    <div class="template-card">
                        <div class="tc-header">
                            <h3 class="tc-title">Express API Setup</h3>
                            <span class="tc-icon">⚡</span>
                        </div>
                        <p class="tc-desc">A complete boilerplate for a Node.js Express server with routing, error handling, and basic middleware.</p>
                        <div class="tc-tags">
                            <span class="tc-tag">JavaScript</span>
                            <span class="tc-tag">Backend</span>
                            <span class="tc-tag">Express</span>
                        </div>
                        <div class="tc-footer">
                            <span style="color:var(--text-secondary); font-size:0.85rem;">Used 1.2k times</span>
                            <a href="/app" class="tc-btn">Use Template</a>
                        </div>
                    </div>

                    <!-- Template 2 -->
                    <div class="template-card">
                        <div class="tc-header">
                            <h3 class="tc-title">React Auth context</h3>
                            <span class="tc-icon">⚛️</span>
                        </div>
                        <p class="tc-desc">A robust React Context provider for user authentication, including JWT token management and protected routes.</p>
                        <div class="tc-tags">
                            <span class="tc-tag">React</span>
                            <span class="tc-tag">Frontend</span>
                            <span class="tc-tag">Auth</span>
                        </div>
                        <div class="tc-footer">
                            <span style="color:var(--text-secondary); font-size:0.85rem;">Used 845 times</span>
                            <a href="/app" class="tc-btn">Use Template</a>
                        </div>
                    </div>

                    <!-- Template 3 -->
                    <div class="template-card">
                        <div class="tc-header">
                            <h3 class="tc-title">Binary Search Tree</h3>
                            <span class="tc-icon">🌳</span>
                        </div>
                        <p class="tc-desc">An elegant and optimized Python implementation of a Binary Search Tree with insertion, deletion, and traversal methods.</p>
                        <div class="tc-tags">
                            <span class="tc-tag">Python</span>
                            <span class="tc-tag">Algorithms</span>
                            <span class="tc-tag">Data Structures</span>
                        </div>
                        <div class="tc-footer">
                            <span style="color:var(--text-secondary); font-size:0.85rem;">Used 2.4k times</span>
                            <a href="/app" class="tc-btn">Use Template</a>
                        </div>
                    </div>

                    <!-- Template 4 -->
                    <div class="template-card">
                        <div class="tc-header">
                            <h3 class="tc-title">Tailwind CSS Modal</h3>
                            <span class="tc-icon">🪟</span>
                        </div>
                        <p class="tc-desc">An accessible, fully-styled HTML/Tailwind CSS modal with backdrop blur and enter/leave animations.</p>
                        <div class="tc-tags">
                            <span class="tc-tag">HTML</span>
                            <span class="tc-tag">CSS</span>
                            <span class="tc-tag">UI/UX</span>
                        </div>
                        <div class="tc-footer">
                            <span style="color:var(--text-secondary); font-size:0.85rem;">Used 3.1k times</span>
                            <a href="/app" class="tc-btn">Use Template</a>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script>
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'light') {
            document.body.classList.add('light-mode');
            document.querySelector('.theme-toggle-btn').textContent = '☀️';
        }

        function toggleTheme() {
            document.body.classList.toggle('light-mode');
            const isLight = document.body.classList.contains('light-mode');
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
            document.querySelector('.theme-toggle-btn').textContent = isLight ? '☀️' : '🌙';
        }
    </script>
</body>
</html>
